#!/bin/bash

# Ensure the script exits when a command fails
set -e

echo "Running go fmt..."
UNFORMATTED=$(go fmt ./...)
if [ -n "$UNFORMATTED" ]; then
    echo "Some files were not formatted. The go fmt tool has been run and modified them."
    echo "Please review and add the changes to your commit."
    exit 1
fi

echo "Running go mod tidy..."
go mod tidy
if ! git diff --exit-code go.mod go.sum > /dev/null; then
    echo "go.mod or go.sum was modified after running 'go mod tidy'. Please add the changes to your commit."
    exit 1
fi

echo "Running golangci-lint..."
if ! golangci-lint run; then
    echo "golangci-lint failed. Please fix the above issues and try committing again."
    exit 1
fi

echo "All code checks passed successfully!"
